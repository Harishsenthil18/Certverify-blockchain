# Copy this file to .env and fill in real values. Never commit .env itself.

FLASK_ENV=development

# Generate a strong random key, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# MySQL connection (matches the certverify_app user created in Phase 2's
# SETUP_INSTRUCTIONS.md -- do NOT use the root MySQL account here)
DB_HOST=localhost
DB_PORT=3306
DB_USER=certverify_app
DB_PASSWORD=ChangeThisStrongPassword!23
DB_NAME=certverify_db

# Used to build the URL embedded in each certificate's QR code.
# Set this to your real deployed domain in production.
VERIFICATION_BASE_URL=http://localhost:5000/verify

# Set to true only when serving over HTTPS
SESSION_COOKIE_SECURE=false
